#!/usr/bin/env python3
"""subagent — Dispatch tasks to named agent sessions.

Usage:
    subagent run [--bg] [--backend <name>] <agent> <session> <prompt>
    subagent run [--bg] <session> <prompt>
    subagent wait <session>
    subagent list
    subagent status <agent> [session]

Agent definitions: .agents/subagent/<agent>.md (Markdown + YAML frontmatter)
"""

import sys
from pathlib import Path

# Add the lib directory and sub-packages to sys.path
_script_dir = Path(__file__).resolve().parent
_lib_dir = _script_dir / "lib"
sys.path.insert(0, str(_lib_dir / "backends"))
sys.path.insert(0, str(_lib_dir / "transports"))
sys.path.insert(0, str(_lib_dir))

from cli import main  # noqa: E402

if __name__ == "__main__":
    main()